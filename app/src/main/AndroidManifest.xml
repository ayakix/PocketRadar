<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

<uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- dataSync, not connectedDevice. We talk to rtl_tcp over a localhost
         TCP socket; the USB / dongle ownership lives in the SDR driver app's
         own process, not ours. connectedDevice would require BLUETOOTH_*,
         NFC, or an approved UsbManager.requestPermission, none of which we
         hold. dataSync needs only the matching FGS permission. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".PocketRadarApp"
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true">

        <!-- secrets-gradle-plugin replaces ${MAPS_API_KEY} from local.properties at build time. -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.RadarForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>
</manifest>
